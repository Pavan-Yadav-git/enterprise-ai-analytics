# =========================================================================
# Real-Time Analytics & Reporting Platform - Environment Variables Template
# Copy this file to .env and modify configurations for your environment.
# =========================================================================

# --- API Server Settings ---
PROJECT_NAME="Real-Time Analytics & Reporting Platform"
API_V1_STR="/api/v1"

# --- Security & JWT Cryptography ---
# IMPORTANT: Override SECRET_KEY in production to a high-entropy 32-character string!
SECRET_KEY="super-secret-jwt-signing-key-for-development-change-in-prod"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database & Ingestion Connectors ---
# Asyncpg driver is required for the async PostgreSQL engine.
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/analytics"
REDIS_URL="redis://localhost:6379/0"

# --- CORS Configurations ---
# Must be standard JSON-string format listing allowed host addresses.
BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://127.0.0.1:3000"]'

# --- Ingestion Rate Limiting Bounds ---
# 1000 requests per minute per organization or API Key
DEFAULT_RATE_LIMIT_LIMIT=1000
DEFAULT_RATE_LIMIT_WINDOW=60

# --- Outbound Mail & Alert Notifications ---
# fallbacks automatically to standard output logging if left blank.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="alerts@analyticsplatform.com"
